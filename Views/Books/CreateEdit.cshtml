@model BookStore.Models.Book

<h2>@(Model.Id == 0 ? "Create Book" : "Edit Book")</h2>

<form asp-action="@ViewContext.RouteData.Values["action"]" method="post">

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input class="form-control" asp-for="Title" />
    </div>

    <div class="mb-3">
        <label class="form-label">Author</label>
        <input class="form-control" asp-for="Author" />
    </div>
    
    <div class="mb-3">
        <label class="form-label">Price</label>
        <input class="form-control" asp-for="Price" type="number" step="0.01" />
    </div>

    <button class="btn btn-success">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Back</a>
</form>