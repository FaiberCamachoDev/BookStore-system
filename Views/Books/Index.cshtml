@model List<BookStore.Models.Book>

<h2>Books</h2>

<a class="btn btn-primary mb-3" asp-action="Create">+ Create Book</a>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Price</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var b in Model)
    {
        <tr>
            <td>@b.Title</td>
            <td>@b.Author</td>
            <td>@b.Price</td>
            <td>
                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@b.Id">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@b.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>