@model List<BookStore.Models.Book>

@section Styles {
    <link rel="stylesheet" href="~/css/books.css" />
}

<div class="page-header">
    <h3>📚 Books</h3>
    <a class="btn btn-primary" asp-action="Create">+ New Book</a>
</div>

<table class="table table-custom">
    <thead>
    <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Price</th>
        <th style="width:150px;">Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var b in Model)
    {
        <tr>
            <td>@b.Title</td>
            <td>@b.Author</td>
            <td>$@b.Price</td>
            <td>
                <a class="btn btn-sm btn-warning btn-action" asp-action="Edit" asp-route-id="@b.Id">Edit</a>
                <a class="btn btn-sm btn-danger btn-action" asp-action="Delete" asp-route-id="@b.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>