@model List<BookStore.Models.Loan>

<h2>Loans</h2>

<a class="btn btn-primary mb-3" asp-action="Create">+ Create Loan</a>

<table class="table table-striped">
    <thead>
    <tr>
        <th>User</th>
        <th>Book</th>
        <th>Date</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var l in Model)
    {
        <tr>
            <td>@l.User?.Name</td>
            <td>@l.Book?.Title</td>
            <td>@l.LoanDate.ToString("g")</td>
            <td>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@l.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>