@model List<BookStore.Models.Loan>

<link rel="stylesheet" href="~/css/loans.css" />

<div class="loans-header">
    <h2>📚 Loans</h2>
    <a class="btn btn-primary" asp-action="Create">+ New Loan</a>
</div>

<div class="loans-card">
    <table class="table table-hover table-loans">
        <thead>
        <tr>
            <th>User</th>
            <th>Book</th>
            <th>Date</th>
            <th>Status</th>
            <th style="width:100px;"></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td>👤 @l.User?.Name</td>
                <td>📖 @l.Book?.Title</td>
                <td>@l.LoanDate.ToString("g")</td>
                <td>
                    <span class="badge-loaned">Loaned</span>
                </td>
                <td>
                    <a class="btn btn-sm btn-danger"
                       asp-action="Delete" asp-route-id="@l.Id">
                        🗑️
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>