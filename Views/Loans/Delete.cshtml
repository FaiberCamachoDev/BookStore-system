@model BookStore.Models.Loan

<link rel="stylesheet" href="~/css/loans.css" />

<div class="loans-card text-center">

    <h3 class="text-danger mb-3">⚠️ Delete Loan</h3>

    <p><strong>User:</strong> @Model.User?.Name</p>
    <p><strong>Book:</strong> @Model.Book?.Title</p>
    <p><strong>Date:</strong> @Model.LoanDate.ToString("g")</p>

    <form method="post" class="mt-4">
        <input type="hidden" asp-for="Id" />

        <button class="btn btn-danger">🗑️ Delete</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </form>

</div>