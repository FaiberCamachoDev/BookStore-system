@model BookStore.ViewModels.LoanViewModel

<link rel="stylesheet" href="~/css/loans.css" />

<div class="loans-card form-card">

    <h3 class="mb-4">📌 Create Loan</h3>

    <form method="post">

        <div class="mb-3">
            <label class="form-label">User</label>
            <select class="form-select" asp-for="UserId">
                <option disabled selected>-- Select user --</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.Id">@u.Name</option>
                }
            </select>
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Book</label>
            <select class="form-select" asp-for="BookId">
                <option disabled selected>-- Select book --</option>
                @foreach (var b in Model.Books)
                {
                    <option value="@b.Id">@b.Title</option>
                }
            </select>
            <span asp-validation-for="BookId" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a class="btn btn-secondary" asp-action="Index">Back</a>
            <button class="btn btn-success">📚 Save Loan</button>
        </div>

    </form>
</div>