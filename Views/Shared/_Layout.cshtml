<!DOCTYPE html>
<html lang="en">
<head>
    
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BookStore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    @RenderSection("Styles", required: false)
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
    <h4 class="text-center py-3 border-bottom">📚 BookStore</h4>
    
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <a asp-controller="Books" asp-action="Index">📖 Books</a>
    <a asp-controller="Users" asp-action="Index">👤 Users</a>
    <a asp-controller="Loans" asp-action="Index">🔄 Loans</a>
</div>

<!-- MAIN -->
<div class="main-content">

    <!-- TOPBAR -->
    <div class="topbar d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@ViewData["Title"]</h5>
    </div>

    <!-- ALERTS -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-@TempData["Type"] alert-dismissible fade show custom-alert" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- CONTENT -->
    <div class="content-card">
        @RenderBody()
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Auto close alerts after 3s
    setTimeout(() => {
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(a => {
            a.classList.remove('show');
            a.classList.add('fade');
        });
    }, 3000);
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>