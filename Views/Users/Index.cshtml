@model List<BookStore.Models.User>

<link rel="stylesheet" href="~/css/users.css" />

<div class="users-header">
    <h2>👤 Users</h2>
    <a class="btn btn-primary" asp-action="Create">+ Create User</a>
</div>

<div class="users-card">
    <table class="table table-hover table-users">
        <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th style="width:150px;"></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Name</td>
                <td>@u.Email</td>
                <td>
                    <a class="btn btn-sm btn-warning btn-action"
                       asp-action="Edit" asp-route-id="@u.Id">
                        ✏️
                    </a>

                    <a class="btn btn-sm btn-danger btn-action"
                       asp-action="Delete" asp-route-id="@u.Id">
                        🗑️
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>