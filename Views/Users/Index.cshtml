@model List<BookStore.Models.User>

<h2>Users</h2>

<a class="btn btn-primary mb-3" asp-action="Create">+ Create User</a>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Name</td>
            <td>@u.Email</td>
            <td>
                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@u.Id">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@u.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>