@model BookStore.Models.User

<link rel="stylesheet" href="~/css/users.css" />

<div class="users-card form-card">

    <h3 class="mb-4">
        @(Model.Id == 0 ? "Create User" : "Edit User")
    </h3>

    <form asp-action="@ViewContext.RouteData.Values["action"]" method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Name</label>
            <input class="form-control" asp-for="Name" placeholder="Enter name..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" asp-for="Email" placeholder="Enter email..." />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a class="btn btn-secondary" asp-action="Index">Back</a>
            <button class="btn btn-success">💾 Save</button>
        </div>
    </form>

</div>